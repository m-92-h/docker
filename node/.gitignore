# 1. Dependency directories (لا نرفع المكتبات أبداً)
node_modules/
jspm_packages/

# 2. Environment variables (الملفات السرية - أهم نقطة)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 3. Build outputs (نتائج البناء التي تتولد تلقائياً)
dist/
build/
.next/
out/

# 4. Logs (ملفات سجلات الأخطاء)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# 5. OS and IDE metadata (ملفات النظام والبرامج)
.DS_Store
Thumbs.db
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# 6. Docker (اختياري - حسب رغبتك)
# عادة نرفع Dockerfile و docker-compose.yml ليتشاركها المبرمجون
# ولكن لا نرفع البيانات المخزنة (Volumes)
data/